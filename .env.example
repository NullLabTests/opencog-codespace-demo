# CogServer configuration
# Copy to .env and edit for your environment

COGSERVER_HOST=localhost
COGSERVER_REPL_PORT=17001
COGSERVER_WEB_PORT=18080
COGSERVER_MCP_PORT=18888

# Build settings (for source build)
CMAKE_BUILD_TYPE=Release
CC=gcc-14
CXX=g++-14

# Docker
DOCKER_IMAGE=opencog-demo
DOCKER_TAG=latest
